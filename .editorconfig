# Cross-editor baseline so files stay consistent regardless of who/what edits them.
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{ts,js}]
indent_size = 2

[*.ps1]
# PowerShell convention is 4-space indent; keep CRLF-agnostic via lf above.
indent_size = 4

[*.md]
trim_trailing_whitespace = false  # trailing spaces can be meaningful (hard line breaks)
